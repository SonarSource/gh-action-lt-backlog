{
  "name": "backlog-automation",
  "version": "1.0.0",
  "description": "BacklogAutomation",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check-dependencies": "npm ls --omit=dev",
    "test": "node --test --test-timeout=20000 \"test/**/*.test.js\"",
    "test-uts": "node --test --test-timeout=20000 \"test/*.test.js\" \"test/!(Data)/**/*.test.js\"",
    "test-data": "node --test --test-timeout=20000 \"test/Data/**/*.test.js\"",
    "format": "prettier --write \"**/*.js\""
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@octokit/graphql": "^9.0.3"
  }
}
